# ============================================================
# Voice AI - .gitignore
# ============================================================

# ─── Python / Backend ───────────────────────────────────────

# Virtual environments
backend/venv/
backend/.venv/
venv/
.venv/
env/
ENV/

# Python cache & compiled files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Type checking
.mypy_cache/
.dmypy.json
.pytype/

# ─── Environment & Secrets ──────────────────────────────────

.env
.env.*
!.env.example
*.local

# ─── Backend Runtime Directories ────────────────────────────

# Uploaded files (user audio/video uploads)
backend/uploads/

# Temporary processing files
backend/temp/

# ─── Node / Frontend ────────────────────────────────────────

node_modules
dist
dist-ssr
*.local

# Vite build output
frontend/dist/
frontend/dist-ssr/

# ─── Logs ───────────────────────────────────────────────────

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Editor & OS Files ──────────────────────────────────────

# VS Code (keep shared settings if desired)
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# JetBrains IDEs
.idea/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Misc ───────────────────────────────────────────────────

*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.bak
*.tmp

English Pronunciation Assessment System Architecture.pdf
